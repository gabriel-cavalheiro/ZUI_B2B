<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        id="idOrgVendasSelectDialog"
        title="Selecione a Org. Vendas"
        items="{view>/orgVendas}"
        search=".onOrgVendasSelectDialogSearch"
        confirm=".onOrgVendasSelectDialogConfirm"
        cancel=".onOrgVendasSelectDialogCancel"
        multiSelect="false">
        <StandardListItem
            id="idOrgVendasStandardListItem"
            title="{view>vkorg}"
            description="{view>vtext}" />
    </SelectDialog>
</core:FragmentDefinition>
