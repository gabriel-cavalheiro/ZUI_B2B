<mvc:View
    controllerName="br.com.inbetta.zsdb2b.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <Page id="page" title="{i18n>appTitle}" enableScrolling="true">

        <content>
            <VBox class="sapUiSmallMargin">

                <!-- ========================== -->
                <!-- Seleção de Processadores   -->
                <!-- ========================== -->
                <Panel expandable="true" expanded="true" headerText="{i18n>secProcessadores}">
                    <VBox class="sapUiSmallMargin">

                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Label text="{i18n>lblTipoCarga}" class="sapUiSmallMarginEnd" />
                            <SegmentedButton id="sbCarga" selectedKey="{view>/tipoCarga}">
                                <items>
                                    <SegmentedButtonItem key="INICIAL" text="{i18n>lblInicial}" />
                                    <SegmentedButtonItem key="INCREMENTAL" text="{i18n>lblIncremental}" />
                                </items>
                            </SegmentedButton>
                        </HBox>

                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Label text="{i18n>lblVkorg}" required="true" class="sapUiSmallMarginEnd" />
                            <Input
                                id="inpVkorg"
                                value="{view>/vkorg}"
                                width="12rem"
                                placeholder="Ex: 1500"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpVkorg"
                                showSuggestion="true"
                                filterSuggests="true"
                                suggestionItemSelected=".onVkorgSuggestionSelected"
                                suggestionItems="{view>/branches}">
                                <suggestionItems>
                                    <core:Item key="{view>branch}" text="{view>branch} - {view>name}" />
                                </suggestionItems>
                            </Input>
                        </HBox>

                        <l:Grid defaultSpan="XL3 L3 M6 S12">
                            <CheckBox id="cbListaPreco" text="{i18n>lblListaPreco}" selected="{view>/processadores/LISTA_PRECO}" select=".onProcessadorSelect" />
                            <CheckBox id="cbImpostos" text="{i18n>lblImpostos}" selected="{view>/processadores/IMPOSTOS}" select=".onProcessadorSelect" />
                            <CheckBox id="cbClientes" text="{i18n>lblClientes}" selected="{view>/processadores/CLIENTES}" select=".onProcessadorSelect" />
                            <CheckBox id="cbProdutos" text="{i18n>lblProdutos}" selected="{view>/processadores/PRODUTOS}" select=".onProcessadorSelect" />
                            <CheckBox id="cbEstoque" text="{i18n>lblEstoque}" selected="{view>/processadores/ESTOQUE}" select=".onProcessadorSelect" />
                            <CheckBox id="cbNF" text="{i18n>lblNF}" selected="{view>/processadores/NF}" select=".onProcessadorSelect" />
                            <CheckBox id="cbOrdemVenda" text="{i18n>lblOrdemVenda}" selected="{view>/processadores/ORDEM_VENDA}" select=".onProcessadorSelect" />
                            <CheckBox id="cbSegmento" text="{i18n>lblSegmento}" selected="{view>/processadores/SEGMENTO}" select=".onProcessadorSelect" />
                        </l:Grid>

                        <HBox class="sapUiSmallMarginTop">
                            <Button text="{i18n>btnSelecionarTodos}" press=".onSelecionarTodos" type="Transparent" icon="sap-icon://multiselect-all" />
                            <Button text="{i18n>btnDesmarcarTodos}" press=".onDesmarcarTodos" type="Transparent" icon="sap-icon://multiselect-none" class="sapUiSmallMarginBegin" />
                        </HBox>
                    </VBox>
                </Panel>

                <!-- ========================= -->
                <!-- Parâmetros Condicionais   -->
                <!-- ========================= -->
                <Panel expandable="true" expanded="true" headerText="{i18n>secParametros}" visible="{view>/temSelecionado}">
                
                    <VBox class="sapUiSmallMargin">
                
                        <!-- LISTA DE PREÇO -->
                        <Panel visible="{view>/processadores/LISTA_PRECO}" headerText="{i18n>lblListaPreco}" class="sapUiTinyMargin paramCard">
                            <VBox class="sapUiSmallMargin">
                                <Label text="{i18n>lblDatum}" />
                                <DatePicker id="dpDatum" value="{view>/params/datum}" displayFormat="dd/MM/yyyy" valueFormat="yyyyMMdd" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblPltyp}" />
                                <Input id="inpPltyp" value="{view>/params/pltyp}" placeholder="Ex: 01,02" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblMater}" />
                                <Input id="inpMater" value="{view>/params/mater}" placeholder="Material (CSV)" width="100%" />
                            </VBox>
                        </Panel>
                
                        <!-- IMPOSTOS -->
                        <Panel visible="{view>/processadores/IMPOSTOS}" headerText="{i18n>lblImpostos}" class="sapUiTinyMargin paramCard">
                            <VBox class="sapUiSmallMargin">
                                <Label text="{i18n>lblDatimp}" />
                                <DatePicker id="dpDatimp" value="{view>/params/datimp}" displayFormat="dd/MM/yyyy" valueFormat="yyyyMMdd" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblTipoImposto}" />
                                <HBox class="sapUiTinyMarginBottom">
                                    <CheckBox text="ICMS" selected="{view>/params/icms}" />
                                    <CheckBox text="IPI" selected="{view>/params/ipi}" class="sapUiSmallMarginBegin" />
                                    <CheckBox text="ST" selected="{view>/params/st}" class="sapUiSmallMarginBegin" />
                                </HBox>
                                <Label text="{i18n>lblGruop}" />
                                <Input id="inpGruop" value="{view>/params/gruop}" placeholder="Grupo (CSV)" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblShipf}" />
                                <Input id="inpShipf" value="{view>/params/shipf}" placeholder="Ship From (CSV)" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblShipt}" />
                                <Input id="inpShipt" value="{view>/params/shipt}" placeholder="Ship To (CSV)" width="100%" />
                            </VBox>
                        </Panel>
                
                        <!-- CLIENTES -->
                        <Panel visible="{view>/processadores/CLIENTES}" headerText="{i18n>lblClientes}" class="sapUiTinyMargin paramCard">
                            <VBox class="sapUiSmallMargin">
                                <Label text="{i18n>lblTipoCliente}" />
                                <HBox class="sapUiTinyMarginBottom">
                                    <CheckBox text="Positivados" selected="{view>/params/positivados}" />
                                    <CheckBox text="Rejeitados" selected="{view>/params/rejeitados}" class="sapUiSmallMarginBegin" />
                                </HBox>
                                <Label text="{i18n>lblKunnr}" />
                                <Input id="inpKunnr" value="{view>/params/kunnr}" placeholder="Cliente (CSV)" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblErdatk}" />
                                <Input id="inpErdatk" value="{view>/params/erdatk}" placeholder="Data criação (CSV)" width="100%" />
                            </VBox>
                        </Panel>
                
                        <!-- PRODUTOS -->
                        <Panel visible="{view>/processadores/PRODUTOS}" headerText="{i18n>lblProdutos}" class="sapUiTinyMargin paramCard">
                            <VBox class="sapUiSmallMargin">
                                <Label text="{i18n>lblMatnr}" />
                                <Input id="inpMatnr" value="{view>/params/matnr}" placeholder="Material (CSV)" width="100%" class="sapUiTinyMarginBottom" />
                                <HBox class="sapUiTinyMarginBottom">
                                    <VBox class="sapUiTinyMarginEnd" width="50%">
                                        <Label text="{i18n>lblVtweg}" />
                                        <Input id="inpVtweg" value="{view>/params/vtweg}" placeholder="Ex: 10" width="100%" />
                                    </VBox>
                                    <VBox width="50%">
                                        <Label text="{i18n>lblWerks}" />
                                        <Input id="inpWerks" value="{view>/params/werks}" placeholder="Ex: 1500" width="100%" />
                                    </VBox>
                                </HBox>
                                <HBox>
                                    <VBox class="sapUiTinyMarginEnd" width="50%">
                                        <Label text="{i18n>lblMtart}" />
                                        <Input id="inpMtart" value="{view>/params/mtart}" placeholder="Ex: FERT" width="100%" />
                                    </VBox>
                                    <VBox width="50%">
                                        <Label text="{i18n>lblLgort}" />
                                        <Input id="inpLgort" value="{view>/params/lgort}" placeholder="Ex: 0001" width="100%" />
                                    </VBox>
                                </HBox>
                            </VBox>
                        </Panel>
                
                        <!-- ESTOQUE -->
                        <Panel visible="{view>/processadores/ESTOQUE}" headerText="{i18n>lblEstoque}" class="sapUiTinyMargin paramCard">
                            <VBox class="sapUiSmallMargin">
                                <Label text="{i18n>lblMatest}" />
                                <Input id="inpMatest" value="{view>/params/matest}" placeholder="Material estoque (CSV)" width="100%" />
                            </VBox>
                        </Panel>
                
                        <!-- NOTA FISCAL -->
                        <Panel visible="{view>/processadores/NF}" headerText="{i18n>lblNF}" class="sapUiTinyMargin paramCard">
                            <VBox class="sapUiSmallMargin">
                                <Label text="{i18n>lblBranch}" />
                                <Input id="inpBranch" value="{view>/params/branch}" placeholder="Branch (CSV)" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblCredat}" />
                                <Input id="inpCredat" value="{view>/params/credat}" placeholder="Data criação (CSV)" width="100%" />
                            </VBox>
                        </Panel>
                
                        <!-- ORDEM DE VENDA -->
                        <Panel visible="{view>/processadores/ORDEM_VENDA}" headerText="{i18n>lblOrdemVenda}" class="sapUiTinyMargin paramCard">
                            <VBox class="sapUiSmallMargin">
                                <Label text="{i18n>lblErdat}" />
                                <Input id="inpErdat" value="{view>/params/erdat}" placeholder="Data criação (CSV)" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblVbeln}" />
                                <Input id="inpVbeln" value="{view>/params/vbeln}" placeholder="Nº OV (CSV)" width="100%" />
                            </VBox>
                        </Panel>
                
                        <!-- SEGMENTO -->
                        <Panel visible="{view>/processadores/SEGMENTO}" headerText="{i18n>lblSegmento}" class="sapUiTinyMargin paramCard">
                            <VBox class="sapUiSmallMargin">
                                <Label text="{i18n>lblDatbi}" />
                                <DatePicker id="dpDatbi" value="{view>/params/datbi}" displayFormat="dd/MM/yyyy" valueFormat="yyyyMMdd" width="100%" class="sapUiTinyMarginBottom" />
                                <Label text="{i18n>lblZtag1}" />
                                <Input id="inpZtag1" value="{view>/params/ztag1}" placeholder="Ex: X" width="6rem" />
                            </VBox>
                        </Panel>
                
                    </VBox>
                </Panel>

                <!-- ==================== -->
                <!-- Resultados           -->
                <!-- ==================== -->
                <Panel id="panelResultado" expandable="true" expanded="true" headerText="{i18n>secResultado}" visible="{view>/resultadoVisivel}">

                    <Table id="tblResultados" items="{view>/resultados}" sticky="ColumnHeaders">
                        <columns>
                            <Column width="12rem"><Text text="{i18n>colProcessador}" /></Column>
                            <Column width="6rem" hAlign="Center"><Text text="{i18n>colStatus}" /></Column>
                            <Column><Text text="{i18n>colMensagens}" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <Text text="{view>processor}" />
                                <ObjectStatus
                                    text="{view>statusText}"
                                    state="{= ${view>status} === 'S' ? 'Success' : (${view>status} === 'E' ? 'Error' : 'Warning') }"
                                    icon="{= ${view>status} === 'S' ? 'sap-icon://accept' : (${view>status} === 'E' ? 'sap-icon://error' : 'sap-icon://alert') }" />
                                <Text text="{view>mensagem}" />
                            </ColumnListItem>
                        </items>
                    </Table>

                </Panel>

            </VBox>
        </content>

        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    id="btnExecutar"
                    text="{i18n>btnExecutar}"
                    type="Emphasized"
                    press=".onExecutar"
                    icon="sap-icon://process"
                    enabled="{view>/temSelecionado}" />
                <Button
                    id="btnLimpar"
                    text="{i18n>btnLimpar}"
                    press=".onLimpar"
                    icon="sap-icon://clear-filter" />
            </Toolbar>
        </footer>

    </Page>
</mvc:View>